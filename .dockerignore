# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Secrets — always excluded from image
.env
!.env.example

# IDE / editor
.vscode/
.idea/
.cursor/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Logs
*.log

# Test CSV files (large; not needed at runtime)
test_*.csv

# Docker files themselves (no need to copy into image)
Dockerfile
docker-compose.yml
.dockerignore
