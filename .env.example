# ── TrendScanner AI — environment template ────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# The .env file is git-ignored and never baked into the Docker image.

# Required for AI summary tab (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: live INR price hints via Google Shopping
SERPAPI_API_KEY=your_serpapi_key_here

# Optional: USD → INR conversion rate (default 83.0)
USD_TO_INR_RATE=83.0
