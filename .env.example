# TrendScanner AI — copy to .env and fill in your keys (never commit .env)

# Required for AI summary tab (Groq — free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Use built-in template summary if Groq fails or key is missing (default: true)
# LLM_ALLOW_LOCAL_FALLBACK=true

# Optional: live INR price hints via Google Shopping (parallel lookups)
# SERPAPI_API_KEY=
# SERPAPI_MAX_QUERIES=10
# SERPAPI_MAX_WORKERS=6
# SERPAPI_TIMEOUT_SEC=12

# USD → INR conversion (default 83.0)
# USD_TO_INR_RATE=83.0

# Email (SMTP or Brevo)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=TrendScanner AI
# SMTP_USE_TLS=true
# EMAIL_PROVIDER=smtp
# BREVO_API_KEY=
